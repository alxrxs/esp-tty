# sdkconfig.zero.defaults -- delta overrides for the Waveshare ESP32-S3-Zero
# Applied on top of sdkconfig.defaults via:
#   -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.zero.defaults"
#
# The Zero carries the ESP32-S3FH4R2: 4 MB embedded QIO flash + 2 MB embedded
# QSPI PSRAM.  These settings override the N16R8-specific values in
# sdkconfig.defaults.

# -- Flash (4 MB, QIO) -------------------------------------------------------
# Override: sdkconfig.defaults sets CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
# Flash mode and frequency are the same as N16R8 -- no override needed.

# -- Partition table ---------------------------------------------------------
# ESP-IDF requires CONFIG_PARTITION_TABLE_CUSTOM=y before the filename key
# takes effect.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_zero.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions_zero.csv"

# -- PSRAM (2 MB Quad QSPI) --------------------------------------------------
# Override: sdkconfig.defaults sets CONFIG_SPIRAM_MODE_OCT=y for 8 MB OPI PSRAM.
# The Zero has a 2 MB QSPI part (in-package on FH4R2); use Quad mode instead.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=n
CONFIG_SPIRAM_MODE_QUAD=y

# Quad PSRAM type: auto-detect covers the embedded 2 MB part.
CONFIG_SPIRAM_TYPE_AUTO=y

# -- Wi-Fi stability tweaks for FH4R2 + Quad PSRAM --------------------------
# Without these, the Zero panics in ppRxFragmentProc (LoadProhibited at
# EXCVADDR=0x00000004) shortly after the first outbound TCP SYN -- the WiFi
# RX reassembly path dereferences a NULL fragment header under sustained
# load.  Disabling A-MPDU aggregation puts the RX path on the simpler
# synchronous code path; disabling power save removes the modem-sleep wake
# timing race.  Cost is small throughput; gain is reliability.
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=n
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n
CONFIG_PM_ENABLE=n

# Pull extra WiFi code paths into IRAM so WiFi RX never trips into a "cache
# disabled but cached memory region accessed" panic when the flash cache is
# briefly suspended (CACHE-126 errata on v0.0/v0.1/v0.2 ESP32-S3 silicon).
# Costs ~10 KB IRAM; mandatory on the Zero's FH4R2 v0.2 die.
CONFIG_ESP_WIFI_EXTRA_IRAM_OPT=y
CONFIG_ESP_WIFI_SLP_IRAM_OPT=y

