# User credentials -- never commit
main/config.h

# OTA signing keys -- generated by scripts/gen_ota_key.sh, never commit real keys
ota_keys/sign.key.pem
ota_keys/sign.pub.pem
ota_keys/aes.key
!ota_keys/*.example
!ota_keys/README.md

# EAP-TLS certificates -- real certs are gitignored; only .example files are tracked
main/certs/*.pem
main/certs/*.crt
main/certs/*.key
!main/certs/*.example
!main/certs/README.md

# PlatformIO build artifacts
.pio/

# Generated sdkconfig (committed: sdkconfig.defaults only)
sdkconfig
sdkconfig.*
!sdkconfig.defaults

# ESP-IDF managed components cache
managed_components/
dependencies.lock

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Python bytecode (test scripts)
__pycache__/
*.pyc
