# User credentials -- never commit
# Active config: main/config.h
# Per-device configs: main/config.<devname>.h (multi-ESP32 setups)
# Build-script backups: main/config.h.*.bak (NTP build-matrix etc.)
# Only main/config.example.h is tracked.
main/config.h
main/config.h.*
main/config.*.h
!main/config.example.h

# EAP-TLS certificates -- real certs are gitignored; only .example files are tracked
main/certs/*.pem
main/certs/*.crt
main/certs/*.key
!main/certs/*.example
!main/certs/README.md

# PlatformIO build artifacts
.pio/

# Generated sdkconfig (committed: sdkconfig.defaults only)
sdkconfig
sdkconfig.*
!sdkconfig.defaults
!sdkconfig.zero.defaults

# ESP-IDF managed components cache
managed_components/
dependencies.lock

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Python bytecode (test scripts)
__pycache__/
*.pyc
.claude/
